# 🤖 Platinum: Headless Fleet Agent (Interactive CLI Mode)
# Use this Dockerfile to run the Fleet Tech Lead session locally
# without needing Slack or a server.

FROM python:3.12-slim AS base

ENV DEBIAN_FRONTEND=noninteractive
ENV PATH="/home/agent/.local/bin:/usr/local/bin:$PATH"
ENV HOME="/home/agent"

# 1. Install System Dependencies (Consolidated)
RUN apt-get update && apt-get install -y \
    curl git procps gnupg nodejs npm \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh glab \
    && rm -rf /var/lib/apt/lists/*

# 2. Install Tools (Static Layers)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Install Gemini and MCP Servers
RUN npm install -g @google/gemini-cli@latest \
    @zereight/mcp-gitlab \
    @sentry/mcp-server \
    @roychri/mcp-server-asana

# 3. Create User & Workspace
RUN groupadd -g 1001 agent && \
    useradd -u 1001 -g agent -m -s /bin/bash agent && \
    mkdir -p /workspace/repos /home/agent/app /home/agent/.gemini && \
    chown -R agent:agent /workspace /home/agent

USER agent
WORKDIR /home/agent/app

# 4. Pre-install Python Dependencies (Cacheable Layer)
COPY --chown=agent:agent app/pyproject.toml app/uv.lock ./
# Create venv outside the app directory to prevent host mount conflicts
ENV UV_PROJECT_ENVIRONMENT="/home/agent/.venv"
RUN uv sync --frozen --no-install-project

# 5. Copy Application Code & Configs
WORKDIR /workspace
COPY --chown=agent:agent app/ /home/agent/app/
COPY --chown=agent:agent fleet_config.json ./
COPY --chown=agent:agent FLEET_AGENT.md ./GEMINI.md
COPY --chown=agent:agent scripts/ ./scripts/
COPY --chown=agent:agent prompts/ ./prompts/
COPY --chown=agent:agent skills/ ./.gemini/skills/
COPY --chown=agent:agent workflows/ ./.gemini/workflows/
COPY --chown=agent:agent .gemini/ ./.gemini/

# Ensure skills are also available in the home directory for the CLI
RUN ln -s /workspace/.gemini/skills /home/agent/.gemini/skills

# Final setup
ENV PATH="/home/agent/.venv/bin:$PATH"
ENV WORKSPACE_ROOT="/workspace"
ENV SESSIONS_ROOT="/workspace/sessions"

# EXPOSE NO PORTS - This is an interactive CLI container

# Launch directly into the Fleet Shell
ENTRYPOINT ["/bin/bash", "/workspace/scripts/fleet-shell.sh"]
