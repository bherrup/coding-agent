apiVersion: v1
kind: Secret
metadata:
  name: fleet-agent-secrets
type: Opaque
stringData:
  # --- CORE AUTH ---
  GEMINI_API_KEY: "your-gemini-api-key"

  # --- GIT AUTH ---
  # GitLab PAT for glab CLI (Required for private GitLab repos)
  GITLAB_PAT: "your-gitlab-personal-access-token"
  # GitHub Token for gh CLI (Required for external repos)
  GITHUB_TOKEN: "your-github-personal-access-token"

  # --- MCP & FLEET AUTH ---
  # These keys MUST match the environment variable mappings in deployment.yaml
  ASANA_PAT: "your-asana-access-token"
  SLACK_APP_TOKEN: "xapp-..."
  SLACK_BOT_TOKEN: "xoxb-..."
  SENTRY_DSN: "https://your-sentry-dsn"
  SENTRY_TOKEN: "your-sentry-auth-token"

  # --- EXTENSIONS ---
  STITCH_API_KEY: "your-stitch-api-key"
